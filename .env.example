# Sonic 3 A.I.R. Portable - Build configuration
# Copy this file to .env and adjust values to your setup.

# ── ROM ──────────────────────────────────────────────────────────────────
# Path to the Sonic 3 & Knuckles ROM file.
# The ROM is NOT included in the Sonic 3 A.I.R. download.
# See: https://docs.google.com/document/d/1oSud8dJHvdfrYbkGCfllAOp3JuTks7z4K5SwtVkXkx0
ROM_PATH=

# ── Versions ─────────────────────────────────────────────────────────────
# Sonic 3 A.I.R. release tag (used for download URL).
# Check https://github.com/Eukaryot/sonic3air/releases for available versions.
GAME_VERSION=v24.02.02.0-stable

# PortableApps.com Application Template version.
TEMPLATE_VERSION=3.9.0

# PortableApps.com Installer tool (used by src/scripts/paf.sh).
# Leave empty to auto-detect from common install paths or auto-download.
# Set to the full path of PortableApps.comInstaller.exe to skip detection.
# Example: PA_TOOL_PATH=C:\PortableApps\PortableApps.comInstaller\PortableApps.comInstaller.exe
PA_TOOL_PATH=

# Version to download if the tool is not found locally (fallback only).
PA_INSTALLER_VERSION=3.9.0
